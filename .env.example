# =========================================
# ENTANGLE - Variables de Entorno
# =========================================
#
# Copia este archivo a `.env` y configura las URLs correctas.
# Vite expone variables que empiezan con VITE_ al código del frontend.

# === BACKEND API ===
# URL del backend FastAPI
# Desarrollo local: http://localhost:8000
# Producción Azure: https://tu-backend.azurewebsites.net

VITE_API_URL=http://localhost:8000

# === MODO DE DESARROLLO ===
# Habilita logs adicionales en consola
VITE_DEBUG=true
