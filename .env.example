# =========================================
# ENTANGLE FRONTEND - Variables de Entorno
# =========================================
#
# Copia este archivo a `.env.local` para desarrollo
# Vite expone variables que empiezan con VITE_ al código del frontend

# ================== BACKEND API ==================
# URL del backend FastAPI (incluye /api/v1)
# 
# Desarrollo local:
#   VITE_API_URL=http://localhost:8000/api/v1
#
# Producción (Azure Container Apps):
#   VITE_API_URL=https://ca-xxxxx-api.azurecontainerapps.io/api/v1
#
VITE_API_URL=http://localhost:8000/api/v1

# ================== DEBUG ==================
# Habilita logs adicionales en consola
VITE_DEBUG=true
